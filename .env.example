# Neon connection string with connection pooling (port 6543) - used by Next.js app
DATABASE_URL="postgresql://user:pass@ep-pooler-name.us-east-2.aws.neon.tech/joyerialis?sslmode=require&pgbouncer=true"

# Neon direct connection string (port 5432) - used for Prisma migrations
DIRECT_URL="postgresql://user:pass@ep-direct-name.us-east-2.aws.neon.tech/joyerialis?sslmode=require"

# NextAuth secret key used to encrypt session tokens
NEXTAUTH_SECRET="use-a-strong-random-32-char-key-for-token-signing"

# Root URL of the administrative panel
NEXTAUTH_URL="http://localhost:3000"
